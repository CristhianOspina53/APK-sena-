<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.ApkSENA" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/sena_green</item>
        <item name="colorPrimaryVariant">@color/sena_green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/sena_blue</item>
        <item name="android:colorBackground">@color/background</item>
    </style>
    <style name="Theme.ApkSENA" parent="Base.Theme.ApkSENA" />

    <!-- Input style -->
    <style name="SenaInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/sena_green</item>
        <item name="hintTextColor">@color/sena_green</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Primary Button -->
    <style name="SenaButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/sena_green</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Text Button -->
    <style name="SenaTextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/sena_green</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
