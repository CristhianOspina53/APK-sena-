# ============================================================
#  .htaccess — Rewrite para Apache
#  Coloca este archivo en /api/senaUsuario/.htaccess
#  o en la raíz del proyecto si está en /api/
# ============================================================

Options -Indexes
RewriteEngine On

# Redirigir todo al index.php (excepto archivos/carpetas reales)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# Seguridad básica: negar acceso a archivos de configuración
<FilesMatch "\.(env|json|lock|md|sql)$">
    Order allow,deny
    Deny from all
</FilesMatch>
